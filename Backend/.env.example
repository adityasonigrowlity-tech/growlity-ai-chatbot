# Backend Environment Variables
PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/grow-ai-chatbot?retryWrites=true&w=majority
GOOGLE_GEMINI_API_KEY=your_gemini_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
CORS_ORIGIN=http://localhost:5173

# Note: In production, CORS_ORIGIN should be your website URL
